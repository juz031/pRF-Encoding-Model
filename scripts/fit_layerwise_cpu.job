#!/bin/bash
#SBATCH --output=/home/junruz/prf_model/scripts/slurm_out/slurm-%j.out
#SBATCH -N 1
#SBATCH --job-name=prf_model
#SBATCH --time=10-00:00:00
#SBATCH -p cpu
#SBATCH --mem=32G


echo "SLURM_JOBID: " $SLURM_JOBID
source activate env2025
cd /home/junruz/prf_model/

python fit_prf_model_layerwise.py \
--save_root /user_data/junruz/prf_models/svd_sklearn \
--layer_name layer1